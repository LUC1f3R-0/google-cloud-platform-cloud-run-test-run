# Dependencies and build output (rebuilt inside the image)
node_modules
dist

# Version control and editor
.git
.gitignore
.cursor
.idea

# Local env (Cloud Run / CI must inject secrets; never bake .env into images)
.env
.env.*

# Tests and coverage (not needed to compile the service)
coverage
.nyc_output
test
**/*.spec.ts
**/*.e2e-spec.ts

# Logs and misc
*.log
npm-debug.log*
.DS_Store
README.md
